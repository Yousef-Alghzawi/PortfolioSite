---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

const figures = [
  { src: '/assets/projects/meta-analysis-proportions/plots/forest-mortality-Technique%20A.jpg', caption: 'Pooled mortality - Technique A (Freeman-Tukey)' },
  { src: '/assets/projects/meta-analysis-proportions/plots/forest-mortality-Technique%20B.jpg', caption: 'Pooled mortality - Technique B' },
  { src: '/assets/projects/meta-analysis-proportions/plots/forest-thrombosis-Technique%20A.jpg', caption: 'Pooled thrombosis - Technique A' },
  { src: '/assets/projects/meta-analysis-proportions/plots/forest-thrombosis-Technique%20B.jpg', caption: 'Pooled thrombosis - Technique B' },
];

const cleaning = `# -- Libraries -----------------------------------------------
library(readxl)
library(dplyr)
library(meta)
library(metafor)

# -- Load extracted data ------------------------------------
dat <- read_excel("data/study_extract.xlsx", sheet = "Main")

# -- Prepare proportion outcome: Approach A -----------------
prop_a <- dat %>%
  filter(arm == "A", !is.na(outcome_1_event), !is.na(outcome_1_total)) %>%
  mutate(
    events = as.integer(outcome_1_event),
    total  = as.integer(outcome_1_total),
    label  = paste0(year, " - ", study_id)
  ) %>%
  arrange(year)

# -- Proportion pooling with Freeman-Tukey PFT --------------
meta_prop_a <- metaprop(
  event = prop_a$events,
  n     = prop_a$total,
  studlab = prop_a$label,
  sm    = "PFT",        # Freeman-Tukey double arcsine
  method.ci = "CP",     # Clopper-Pearson exact CI
  method.tau = "DL",    # DerSimonian-Laird τ²
  random = TRUE,
  fixed  = FALSE,
  title  = "Outcome 1 - Approach A"
)
summary(meta_prop_a)

# -- Proportion pooling: Approach B -------------------------
prop_b <- dat %>%
  filter(arm == "B", !is.na(outcome_1_event), !is.na(outcome_1_total)) %>%
  mutate(
    events = as.integer(outcome_1_event),
    total  = as.integer(outcome_1_total),
    label  = paste0(year, " - ", study_id)
  ) %>%
  arrange(year)

meta_prop_b <- metaprop(
  event = prop_b$events,
  n     = prop_b$total,
  studlab = prop_b$label,
  sm    = "PFT",
  method.ci = "CP",
  method.tau = "DL",
  random = TRUE,
  fixed  = FALSE,
  title  = "Outcome 1 - Approach B"
)

# -- Continuous outcome: metamean() with MRAW ---------------
cont_a <- dat %>%
  filter(arm == "A", !is.na(mean_val), !is.na(sd_val)) %>%
  mutate(label = paste0(year, " - ", study_id))

meta_mean_a <- metamean(
  n    = cont_a$n,
  mean = cont_a$mean_val,
  sd   = cont_a$sd_val,
  studlab = cont_a$label,
  sm   = "MRAW",
  method.tau = "REML",
  random = TRUE,
  fixed  = FALSE,
  title  = "Continuous Outcome - Approach A"
)
summary(meta_mean_a)`;

const analysis = `# -- Forest plot: Proportion outcome -------------------------
png("results/forest_prop_approach_a.png", width = 1920, height = 1080, res = 140)
forest(meta_prop_a,
       leftcols  = c("studlab", "event", "n"),
       leftlabs  = c("Study (Year)", "Events", "N"),
       rightcols = c("effect", "ci"),
       rightlabs = c("Proportion", "95% CI"),
       print.tau2 = TRUE,
       print.I2   = TRUE,
       col.diamond = "#7A5B92")
dev.off()

png("results/forest_prop_approach_b.png", width = 1920, height = 1080, res = 140)
forest(meta_prop_b,
       leftcols  = c("studlab", "event", "n"),
       leftlabs  = c("Study (Year)", "Events", "N"),
       print.tau2 = TRUE,
       print.I2   = TRUE,
       col.diamond = "#CEDC57")
dev.off()

# -- Forest plot: Continuous outcome ------------------------
png("results/forest_mean_approach_a.png", width = 1920, height = 1080, res = 140)
forest(meta_mean_a,
       leftcols  = c("studlab", "n", "mean", "sd"),
       leftlabs  = c("Study", "N", "Mean", "SD"),
       print.tau2 = TRUE,
       print.I2   = TRUE)
dev.off()

# -- Heterogeneity summary ---------------------------------
cat("Approach A - Proportion:\\n")
cat("  I² =", meta_prop_a$I2, "\\n")
cat("  τ² =", meta_prop_a$tau2, "\\n")
cat("  Q  =", meta_prop_a$Q, " p =", meta_prop_a$pval.Q, "\\n\\n")

cat("Approach B - Proportion:\\n")
cat("  I² =", meta_prop_b$I2, "\\n")
cat("  τ² =", meta_prop_b$tau2, "\\n")
cat("  Q  =", meta_prop_b$Q, " p =", meta_prop_b$pval.Q, "\\n\\n")

cat("Approach A - Continuous:\\n")
cat("  I² =", meta_mean_a$I2, "\\n")
cat("  τ² =", meta_mean_a$tau2, "\\n")
cat("  Q  =", meta_mean_a$Q, " p =", meta_mean_a$pval.Q, "\\n")`;

const plotting = `# -- Funnel plot: Approach A proportion ----------------------
png("results/funnel_prop_a.png", width = 1200, height = 900, res = 140)
funnel(meta_prop_a,
       xlab = "Proportion (Freeman-Tukey)",
       studlab = TRUE,
       cex.studlab = 0.7)
dev.off()

# -- Egger regression test for funnel asymmetry -------------
# Convert metaprop to metafor rma object for Egger test
rma_prop_a <- rma(
  yi = meta_prop_a$TE,
  sei = meta_prop_a$seTE,
  method = "DL"
)

egger_result <- regtest(rma_prop_a, model = "lm")
cat("Egger regression test:\\n")
cat("  z =", egger_result$zval, "\\n")
cat("  p =", egger_result$pval, "\\n")

# -- Trim-and-fill analysis --------------------------------
tf_result <- trimfill(rma_prop_a)
cat("\\nTrim-and-fill:\\n")
cat("  Imputed studies:", tf_result$k0, "\\n")
cat("  Adjusted estimate:", tf_result$beta, "\\n")
cat("  Original estimate:", rma_prop_a$beta, "\\n")

png("results/funnel_trimfill_a.png", width = 1200, height = 900, res = 140)
funnel(tf_result,
       xlab = "Proportion (Freeman-Tukey)",
       main = "Trim-and-Fill Funnel Plot")
dev.off()

# -- Funnel plot: Approach B proportion ---------------------
png("results/funnel_prop_b.png", width = 1200, height = 900, res = 140)
funnel(meta_prop_b,
       xlab = "Proportion (Freeman-Tukey)",
       studlab = TRUE,
       cex.studlab = 0.7)
dev.off()

rma_prop_b <- rma(
  yi = meta_prop_b$TE,
  sei = meta_prop_b$seTE,
  method = "DL"
)

egger_b <- regtest(rma_prop_b, model = "lm")
cat("\\nApproach B - Egger test:\\n")
cat("  z =", egger_b$zval, "  p =", egger_b$pval, "\\n")

tf_b <- trimfill(rma_prop_b)
cat("  Trim-and-fill imputed:", tf_b$k0, "\\n")`;

const code = [
  { id: 'code-cleaning', label: 'Data Preparation & Proportion Meta-Analysis', code: cleaning },
  { id: 'code-analysis', label: 'Forest Plots & Heterogeneity Assessment', code: analysis },
  { id: 'code-plotting', label: 'Publication Bias & Sensitivity', code: plotting },
];
---
<CaseStudyLayout
  title="Stent vs. Frozen Elephant Trunk"
  description="Case study: proportion meta-analysis with the Freeman-Tukey transformation comparing surgical techniques in Type A aortic dissection. Published in The Thoracic & Cardiovascular Surgeon."
  field="Thoracic Surgery · Proportions"
  venue="Thoracic & CV Surgeon"
  year="2025"
  status="Published"
  doiHref="https://www.thieme-connect.de/products/ejournals/abstract/10.1055/a-2737-6653"
  doiLabel="Thoracic & CV Surgeon: Stent versus Trunk in Type A Dissection"
  problem="Pooling event rates and proportions across studies comparing stent grafting versus frozen elephant trunk in Type A aortic dissection, where studies varied in sample size and reported outcomes, with sparse and zero-event data requiring specialized methods."
  approach="Random-effects proportion pooling with metaprop() using the Freeman-Tukey double-arcsine (PFT) transformation and Clopper-Pearson exact intervals, continuous-outcome pooling via metamean() (MRAW, REML), heterogeneity assessment (I², τ², Q), and publication-bias evaluation through funnel plots, Egger regression, and trim-and-fill."
  outcome="Published in The Thoracic and Cardiovascular Surgeon. The analysis provided comparative effectiveness data for surgical decision-making, and the methodology section required no revision during peer review."
  figures={figures}
  code={code}
  prev={{ slug: 'tevar-zone-ma', title: 'Multi-Outcome Binary Meta-Analysis' }}
  next={{ slug: 'network-meta-analysis', title: 'Bayesian Network Meta-Analysis' }}
/>
