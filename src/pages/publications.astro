---
import Layout from '../layouts/Layout.astro';
import { publications } from '../data/site';

const summary = [
  { v: '6+', d: 'Peer-Reviewed Articles' },
  { v: 'Q1', d: 'Highest Journal Quartile' },
  { v: '21.7', d: 'Highest Impact Factor' },
];
---
<Layout
  title="Publications · Yousef Alghzawi"
  description="Peer-reviewed publications with statistical analysis by Yousef Alghzawi."
>
  <header class="mb-16 md:mb-20 max-w-4xl">
    <p class="eyebrow mb-5">Peer-Reviewed Work</p>
    <h1 class="display-section mb-7">Publications.</h1>
    <p class="lead">
      Selected publications where I contributed statistical analysis, methodology, or evidence
      synthesis. Each demonstrates the rigor and reproducibility I bring to every engagement.
    </p>
  </header>

  <div class="grid gap-4 sm:grid-cols-3 mb-16 md:mb-20">
    {summary.map((x) => (
      <div class="card p-7 text-center">
        <div class="stat-number !text-5xl">{x.v}</div>
        <p class="mono-label mt-3">{x.d}</p>
      </div>
    ))}
  </div>

  <div>
    {publications.map((pub) => (
      <a href={pub.href} target="_blank" rel="noopener noreferrer" class="edit-row group">
        <span class="font-mono text-xs text-accent uppercase tracking-widest leading-relaxed">
          {pub.venue}{pub.impact ? ` · ${pub.impact}` : ''}
        </span>
        <span>
          <span class="font-serif text-xl md:text-2xl leading-snug group-hover:text-accent transition-colors block">{pub.title}</span>
          <span class="text-inkMuted text-sm mt-2 block">{pub.authors}</span>
        </span>
        <span class="font-mono text-[0.7rem] text-inkMuted uppercase tracking-widest whitespace-nowrap">{pub.kind} · {pub.year} →</span>
      </a>
    ))}
  </div>
</Layout>
