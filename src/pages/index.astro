---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../data/site';

const marqueeItems = [
  'JACC', 'Blood', 'JCN', 'Thoracic & CV Surgeon',
  'Meta-Analysis', 'Survival Analysis', 'Bayesian NMA',
  'Mixed Models', 'Reproducible R',
];

const projects = [
  {
    slug: 'tevar-zone-ma',
    eyebrow: 'Vascular Surgery · Meta-Analysis',
    title: 'Multi-Outcome Binary Meta-Analysis',
    blurb: '6 binary outcomes with DerSimonian–Laird, leave-one-out sensitivity, Baujat influence, and country subgroups.',
    status: 'Under Review',
    img: '/assets/projects/meta-analysis-binary/plots/forest-mortality.png',
  },
  {
    slug: 'cns-hematology',
    eyebrow: 'Blood (ASH) · Survival',
    title: 'Second HCT Outcomes',
    blurb: 'Survival analysis with competing risks in hematologic malignancies. Published in Blood.',
    status: 'Published',
    img: '/assets/projects/stratified-cox/plots/os-adjusted.png',
  },
  {
    slug: 'fet-article',
    eyebrow: 'Thoracic Surgery · Proportions',
    title: 'Stent vs. FET Meta-Analysis',
    blurb: 'Proportion pooling with Freeman–Tukey transformation for Type A dissection.',
    status: 'Published',
    img: '/assets/projects/meta-analysis-proportions/plots/forest-mortality-Technique%20A.jpg',
  },
  {
    slug: 'survey-analysis',
    eyebrow: 'Survey Epidemiology',
    title: 'Complex Survey Analysis',
    blurb: 'NHANES multi-cycle weighted analysis with 9 exposure groups.',
    status: '',
    img: '/assets/projects/cross-sectional-prevalence/plots/chart-women.png',
  },
  {
    slug: 'network-meta-analysis',
    eyebrow: 'Network Meta-Analysis',
    title: 'Bayesian NMA',
    blurb: 'Dual-framework NMA with MCMC simulation and treatment ranking.',
    status: '',
    img: '/assets/projects/meta-analysis-continuous/plots/forest-plot-1.png',
  },
];

const publications = [
  { venue: 'JCN', kind: 'Brief Communication', title: 'Cerebrolysin and Risk of Hemorrhagic Transformation: A Pooled Analysis of Recent Studies', href: 'https://doi.org/10.3988/jcn.2025.0547' },
  { venue: 'JACC', kind: 'Statistical Analysis & Methods', title: 'TCT-30 Comparative Meta-Analysis of LVOTO Prevention Techniques in TMVR', href: 'https://www.jacc.org/doi/10.1016/j.jacc.2025.09.079' },
  { venue: 'Blood (ASH)', kind: 'Statistical Analysis & Methods', title: 'Survival Outcomes Following Second Hematopoietic Cell Transplantation', href: 'https://ashpublications.org/blood/article/146/Supplement%201/7802/555052' },
  { venue: 'Thoracic & CV Surgeon', kind: 'Meta-Analysis', title: 'Stent versus Trunk in Type A Dissection: Systematic Review and Meta-Analysis', href: 'https://www.thieme-connect.de/products/ejournals/abstract/10.1055/a-2737-6653' },
];

const services = [
  { t: 'Publication Analysis', d: 'Complete statistical analysis for original research manuscripts, from design through reviewer response.' },
  { t: 'Meta-Analysis', d: 'Systematic reviews with PRISMA-compliant synthesis, heterogeneity assessment, and publication bias evaluation.' },
  { t: 'Trial Strategy', d: 'Pre-trial statistical planning, sample size calculations, and analysis plan development.' },
  { t: 'Methods Audit', d: 'Independent review to identify methodological vulnerabilities before journal submission.' },
];

const process = [
  { n: '1', t: 'Submit Inquiry', d: 'Share your study type, data status, and target journal. I assess fit within 48 hours.' },
  { n: '2', t: 'Scoping Call', d: 'We discuss your research question, endpoints, and reviewer expectations. I draft an analysis plan.' },
  { n: '3', t: 'Analysis & Deliverables', d: 'Full statistical analysis with tables, figures, methods text, and reproducible R code.' },
  { n: '4', t: 'Review & Revisions', d: 'You review the output. I incorporate feedback and prepare the work for submission.' },
  { n: '5', t: 'Post-Submission Support', d: 'Reviewer queries on statistical methods? I draft responses and run additional analyses as needed.' },
];

const tools = ['R / RStudio', 'SPSS', 'PostgreSQL', 'tidyverse', 'survival', 'meta / metafor', 'ggplot2', 'lme4', 'tableone', 'cmprsk', 'R Markdown', 'Joinpoint', 'RevMan'];

const faqs = [
  { q: 'Do you offer authorship or acknowledgment?', a: 'My role is typically acknowledged in the methods section or author list depending on the level of contribution. We discuss this upfront during scoping.' },
  { q: 'How do you handle data confidentiality?', a: 'I sign NDAs and data handling agreements before any data transfer. All datasets are stored on encrypted drives and deleted upon project completion unless otherwise agreed. I am also experienced with de-identified datasets.' },
  { q: 'What if reviewers question the statistical methods?', a: 'Post-submission support is included. I draft point-by-point statistical responses to reviewer queries and run any additional sensitivity or subgroup analyses they request. My goal is that the statistics never become the reason for rejection.' },
  { q: 'Can you work with my existing dataset and analysis?', a: 'Yes. I can audit existing analyses, clean and restructure datasets, or start from raw data. I work with datasets in any format — SPSS (.sav), Excel, CSV, REDCap exports, or SQL databases.' },
  { q: 'What is the typical timeline for a project?', a: 'Most projects take 2–4 weeks for original research and 1–3 weeks for meta-analyses. Timeline depends on dataset complexity, number of endpoints, and revision cycles. I provide a specific estimate during the scoping call.' },
  { q: 'How do we communicate during the project?', a: 'I provide structured progress updates at each milestone. Communication is primarily via email, with video calls for scoping and major review points. You always know where your project stands.' },
  { q: 'Do you help with the study design, or only the analysis?', a: 'Both. I offer pre-study consultation including sample size calculations, endpoint definitions, and study design review. For ongoing studies, I can join at any stage — from protocol development to post-hoc analysis.' },
];
---

<Layout mainClass="flex-1 lg:ml-[280px] px-0">
  <div class="px-4 md:px-12 py-8 md:py-12 space-y-24 md:space-y-36">

    <!-- HERO: living data -->
    <section id="home" class="hero-stage rounded-[32px] border border-white/5 px-6 md:px-14 py-16" data-hero-webgl aria-label="Intro">
      <div class="hero-fallback"></div>
      <div class="hero-vignette"></div>

      <div class="relative max-w-4xl">
        <p class="eyebrow mb-6">Clinical Biostatistics</p>
        <h2 class="display-hero" data-split-reveal>
          Test your hypotheses, and survive peer review.
        </h2>
        <p class="text-uiGray text-lg md:text-xl leading-relaxed max-w-2xl mt-8">
          Publication-grade statistical analysis and reporting aligned with high-impact research standards.
        </p>
        <div class="flex flex-wrap items-center gap-5 mt-10">
          <a href={withBase('/apply')} class="primary-btn" role="button" data-cursor="apply">Apply to Work With Me</a>
          <a href="#work" class="secondary-link text-sm" data-cursor="scroll">See selected work →</a>
        </div>
        <p class="notation text-sm mt-12">HR = 0.72 [0.58–0.89] &nbsp;·&nbsp; p &lt; 0.001 &nbsp;·&nbsp; I² = 42%</p>
      </div>
    </section>

    <!-- KINETIC MARQUEE -->
    <section class="marquee-shell -mx-4 md:-mx-12" data-marquee data-marquee-speed="55" aria-hidden="true">
      <div class="marquee-track">
        {marqueeItems.map((item) => (<span class="marquee-item">{item}</span>))}
      </div>
    </section>

    <!-- INTRO STRIP + animated numbers -->
    <section id="why-me" class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 items-center plot-grid-bg" aria-label="Why Researchers Choose Me">
      <div class="space-y-8">
        <p class="eyebrow">Why Researchers Choose Me</p>
        <h3 class="display-section" data-split-reveal>
          Built for high-impact submissions, every result a signal.
        </h3>
        <p class="text-uiGray text-lg leading-relaxed max-w-xl">
          Every manuscript I have contributed statistical analysis to has been accepted for publication —
          with documented, reproducible R code and a complete audit trail.
        </p>
        <div class="grid grid-cols-3 gap-6 pt-4">
          <div class="reveal-on-scroll">
            <div class="stat-number"><span data-target="6" data-decimals="0">0</span>+</div>
            <p class="notation text-xs mt-2 uppercase tracking-widest">Publications</p>
          </div>
          <div class="reveal-on-scroll">
            <div class="stat-number">Q1</div>
            <p class="notation text-xs mt-2 uppercase tracking-widest">Journal Quartile</p>
          </div>
          <div class="reveal-on-scroll">
            <div class="stat-number">48h</div>
            <p class="notation text-xs mt-2 uppercase tracking-widest">Reviewer Turnaround</p>
          </div>
        </div>
      </div>
      <figure class="relative w-full max-w-sm ml-auto reveal-on-scroll" data-cursor="">
        <div class="absolute inset-0 rounded-[32px] bg-brandOrange/20 blur-2xl -z-10"></div>
        <img src={withBase('/assets/PersonalPhoto.jpg')} width="640" height="800" alt="Portrait of Yousef Alghzawi"
          loading="lazy" class="w-full object-cover rounded-[32px] shadow-xl border border-white/10 max-h-[520px]" data-parallax="40" />
      </figure>
    </section>

    <!-- SERVICES -->
    <section id="services-preview" class="space-y-12" aria-label="Services">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div class="space-y-3">
          <p class="eyebrow">Signature Engagements</p>
          <h3 class="display-section" data-split-reveal>How I work</h3>
        </div>
        <a href={withBase('/services')} class="secondary-link text-base" data-cursor="services">View all services →</a>
      </div>
      <div class="grid gap-4 sm:gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => (
          <article class="glass-card rounded-[24px] p-6 md:p-7 reveal-on-scroll" data-cursor="">
            <div class="font-mono text-brandGreen text-xs tracking-widest mb-4">/ {s.t.split(' ')[0].toUpperCase()}</div>
            <h4 class="font-serif text-2xl mb-3 leading-snug">{s.t}</h4>
            <p class="text-uiGray leading-relaxed">{s.d}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- SELECTED WORK: horizontal pinned gallery -->
    <section id="work" class="space-y-10" aria-label="Selected Work">
      <div class="px-0 md:px-2 space-y-3">
        <p class="eyebrow">Selected Case Studies</p>
        <h3 class="display-section" data-split-reveal>Recent work</h3>
      </div>
      <div class="h-gallery -mx-4 md:-mx-12" data-h-gallery>
        <div class="h-track">
          {projects.map((p) => (
            <article class="h-card" data-cursor="view study">
              <a href={withBase(`/work/${p.slug}`)} class="block h-full group">
                <div class="h-card-media">
                  <img src={withBase(p.img)} alt={p.title} loading="lazy" data-h-parallax />
                </div>
                <div class="h-card-body">
                  <div class="flex items-center gap-3 mb-2">
                    <p class="text-xs text-brandGreen uppercase tracking-widest">{p.eyebrow}</p>
                    {p.status && (
                      <span class="ml-auto text-[0.6rem] uppercase tracking-widest px-2 py-0.5 rounded-full border border-brandGreen/30 text-brandGreen">{p.status}</span>
                    )}
                  </div>
                  <h4 class="font-serif text-2xl leading-snug group-hover:text-brandGreen transition-colors">{p.title}</h4>
                  <p class="text-uiGray text-[15px] leading-relaxed mt-2">{p.blurb}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PUBLICATIONS: editorial list -->
    <section id="publications" class="space-y-10" aria-label="Publications">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div class="space-y-3">
          <p class="eyebrow">Peer-Reviewed</p>
          <h3 class="display-section" data-split-reveal>Recent publications</h3>
        </div>
        <a href={withBase('/publications')} class="secondary-link text-base" data-cursor="all">View all publications →</a>
      </div>
      <div>
        {publications.map((pub) => (
          <a href={pub.href} target="_blank" rel="noopener noreferrer" class="edit-row group reveal-on-scroll" data-cursor="read">
            <span class="font-mono text-xs text-brandGreen uppercase tracking-widest whitespace-nowrap pt-1">{pub.venue}</span>
            <span class="font-serif text-xl md:text-2xl leading-snug group-hover:text-brandGreen transition-colors">{pub.title}</span>
            <span class="font-mono text-[0.7rem] text-uiGray uppercase tracking-widest whitespace-nowrap pt-1 hidden md:inline">{pub.kind} →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="space-y-12 plot-grid-bg" aria-label="How It Works">
      <div class="space-y-3 max-w-2xl">
        <p class="eyebrow">Your Path to Publication</p>
        <h3 class="display-section" data-split-reveal>How it works</h3>
        <p class="text-uiGray text-lg leading-relaxed">From initial inquiry to published manuscript — a transparent, structured process designed for busy clinicians.</p>
      </div>
      <div class="grid gap-6 lg:grid-cols-5">
        {process.map((step) => (
          <div class="reveal-on-scroll border-t border-white/10 pt-5">
            <div class="font-serif text-5xl text-brandGreen mb-4">{step.n}</div>
            <h4 class="font-serif text-xl mb-3 leading-snug">{step.t}</h4>
            <p class="text-uiGray leading-relaxed text-[15px]">{step.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TOOLS -->
    <section id="tools" class="space-y-10" aria-label="Tools and Software">
      <div class="space-y-3">
        <p class="eyebrow">Technical Stack</p>
        <h3 class="display-section" data-split-reveal>Tools &amp; software</h3>
      </div>
      <div class="flex flex-wrap gap-3">
        {tools.map((tool, i) => (
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#2A282B]/70 border border-white/5 text-sm reveal-on-scroll">
            <span class={`w-2 h-2 rounded-full ${i < 3 ? 'bg-brandGreen' : 'bg-brandOrange'}`}></span>{tool}
          </span>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="space-y-12" aria-label="Frequently Asked Questions">
      <div class="space-y-3 text-center">
        <p class="eyebrow">Common Questions</p>
        <h3 class="display-section" data-split-reveal>FAQ</h3>
      </div>
      <div class="max-w-3xl mx-auto space-y-5">
        {faqs.map((f) => (
          <details class="group rounded-2xl glass-card p-5 md:p-7 reveal-on-scroll">
            <summary class="font-serif text-xl text-white cursor-pointer list-none flex items-center justify-between leading-snug" data-cursor="">
              {f.q}
              <svg class="w-5 h-5 text-uiGray group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="text-uiGray text-base mt-5 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="rounded-[32px] glass-card p-10 md:p-16 text-center plot-grid-bg">
      <h3 class="display-section mb-6" data-split-reveal>Ready to discuss your project?</h3>
      <p class="text-uiGray text-lg leading-relaxed mb-10 max-w-3xl mx-auto">
        I take on a limited number of projects each month to ensure each receives the methodological depth and attention it deserves.
      </p>
      <a href={withBase('/apply')} class="primary-btn" data-cursor="apply">Apply to Work With Me</a>
    </section>

  </div>
</Layout>
