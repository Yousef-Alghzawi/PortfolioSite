---
import Layout from '../layouts/Layout.astro';
import { withBase, projects, publications, services, process, faqs, tools } from '../data/site';

const marqueeItems = [
  'JACC', 'Blood · ASH', 'Meta-Analysis', 'Survival Analysis', 'Bayesian NMA',
  'Mixed Models', 'Competing Risks', 'Reproducible R', 'PRISMA 2020', 'Cox Models',
];
const homePublications = publications.slice(0, 4);
---

<Layout mainClass="w-full">
  <!-- SECTION PATH RAIL (desktop) -->
  <nav class="scroll-rail" aria-label="Section navigation">
    <span class="rail-track"></span>
    <span class="rail-fill" id="rail-fill"></span>
    <a href="#home" class="rail-dot" data-rail-dot="home"><span class="rail-label">Intro</span></a>
    <a href="#why-me" class="rail-dot" data-rail-dot="why-me"><span class="rail-label">Why me</span></a>
    <a href="#services" class="rail-dot" data-rail-dot="services"><span class="rail-label">Services</span></a>
    <a href="#work" class="rail-dot" data-rail-dot="work"><span class="rail-label">Work</span></a>
    <a href="#publications" class="rail-dot" data-rail-dot="publications"><span class="rail-label">Papers</span></a>
    <a href="#process" class="rail-dot" data-rail-dot="process"><span class="rail-label">Process</span></a>
    <a href="#faq" class="rail-dot" data-rail-dot="faq"><span class="rail-label">FAQ</span></a>
  </nav>

  <!-- ===================== HERO ===================== -->
  <section class="hero" id="home" data-symbol-field aria-label="Introduction">
    <canvas class="symbol-field" aria-hidden="true"></canvas>
    <div class="field-fallback" aria-hidden="true"></div>
    <div class="hero-veil" aria-hidden="true"></div>

    <div class="w-full max-w-page mx-auto px-[clamp(1.25rem,4vw,3rem)]">
      <div>
        <p class="eyebrow hero-rise d0 mb-7">Clinical Biostatistician · Amman, Jordan</p>
        <h1 class="display-hero hero-rise d1 max-w-[16ch]">Statistics that <em>survive</em> peer review.</h1>
        <p class="lead hero-rise d2 mt-7 md:mt-9 max-w-[54ch]">
          I run the statistical analysis behind your manuscript: rigorous, reproducible, and built to
          satisfy the toughest reviewers. You stay focused on the science; I make sure the numbers hold.
        </p>
        <div class="hero-rise d3 mt-8 md:mt-11 flex flex-wrap items-center gap-4">
          <a href={withBase('/apply')} class="btn-primary">
            Apply to work with me
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
          <a href="#work" class="btn-ghost">See case studies</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== MARQUEE ===================== -->
  <section class="marquee-shell py-5" data-marquee data-marquee-speed="48" aria-hidden="true">
    <div class="marquee-track">
      {marqueeItems.map((item) => (<span class="marquee-item">{item}</span>))}
    </div>
  </section>

  <!-- ===================== BODY ===================== -->
  <div class="max-w-page mx-auto px-[clamp(1.25rem,4vw,3rem)] space-y-20 md:space-y-44 py-16 md:py-40">

    <!-- COMMITMENT -->
    <section class="max-w-4xl">
      <p class="eyebrow mb-7">My commitment</p>
      <p class="display-section reveal-on-scroll">
        Methodology comes first. Always, <em>even when the data is inconvenient.</em>
      </p>
    </section>

    <!-- WHY ME / STATS -->
    <section id="why-me" class="grid lg:grid-cols-[1.15fr_0.85fr] gap-14 lg:gap-20 items-end plot-grid">
      <div>
        <div class="section-head">
          <span class="section-index">§ 01</span>
          <span class="section-kicker">Why researchers choose me</span>
        </div>
        <h2 class="display-section max-w-[16ch]" data-split-reveal>Proof, not promises.</h2>
        <p class="lead mt-8 measure">
          Every manuscript I have supported with statistical analysis has been accepted for publication,
          each backed by documented, reproducible R code and an audit trail you can hand to any reviewer.
        </p>
        <div class="grid grid-cols-3 gap-4 sm:gap-6 mt-10">
          <div class="reveal-on-scroll">
            <div class="stat-number"><span data-target="6" data-suffix="+">0</span></div>
            <p class="mono-label mt-3">Publications</p>
          </div>
          <div class="reveal-on-scroll" style="transition-delay:0.08s">
            <div class="stat-number"><span data-target="21.7" data-decimals="1">0</span></div>
            <p class="mono-label mt-3">Top Impact Factor</p>
          </div>
          <div class="reveal-on-scroll" style="transition-delay:0.16s">
            <div class="stat-number"><span data-target="100" data-suffix="%">0</span></div>
            <p class="mono-label mt-3">Acceptance Rate</p>
          </div>
        </div>
      </div>
      <figure class="reveal-on-scroll relative w-full max-w-sm mx-auto lg:mx-0 lg:ml-auto">
        <img src={withBase('/assets/PersonalPhoto.jpg')} width="640" height="800"
          alt="Portrait of Yousef Alghzawi" loading="lazy"
          class="w-full object-cover rounded-2xl border border-line max-h-[540px]" data-parallax="30" />
        <figcaption class="mono-label mt-4 flex items-center gap-2">
          <span class="inline-block w-2 h-2 rounded-full bg-signal"></span>Yousef Alghzawi, Biostatistician
        </figcaption>
      </figure>
    </section>

    <!-- SERVICES -->
    <section id="services">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-8">
        <div>
          <div class="section-head !mb-6">
            <span class="section-index">§ 02</span>
            <span class="section-kicker">What I deliver</span>
          </div>
          <h2 class="display-section" data-split-reveal>How I work.</h2>
        </div>
        <a href={withBase('/services')} class="link-underline font-mono text-sm">All services →</a>
      </div>
      <div>
        {services.map((s) => (
          <a href={withBase('/services')} class="svc-row group reveal-on-scroll">
            <span class="font-mono text-xs text-accent tracking-widest pt-1">{s.code}</span>
            <span>
              <span class="font-serif text-2xl md:text-3xl leading-tight group-hover:text-accent transition-colors block">{s.title}</span>
              <span class="text-inkSoft leading-relaxed mt-2 block measure">{s.summary}</span>
            </span>
            <span class="mono-label whitespace-nowrap pt-1 hidden md:block">{s.timeline}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- WORK (horizontal gallery) -->
    <section id="work" class="h-gallery" data-h-gallery>
      <div class="flex flex-wrap items-end justify-between gap-6 mb-10">
        <div>
          <div class="section-head !mb-6">
            <span class="section-index">§ 03</span>
            <span class="section-kicker">Selected case studies</span>
          </div>
          <h2 class="display-section" data-split-reveal>The evidence.</h2>
        </div>
        <p class="mono-label hidden lg:block">Scroll to explore →</p>
      </div>
      <div class="h-viewport max-lg:-mx-[clamp(1.25rem,4vw,3rem)] max-lg:px-[clamp(1.25rem,4vw,3rem)]">
        <div class="h-track">
          {projects.map((p) => (
            <a href={withBase(`/work/${p.slug}`)} class="h-card group">
              <div class="h-media">
                <img src={withBase(p.img)} alt={p.title} loading="lazy" />
              </div>
              <div class="h-body">
                <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                  <p class="mono-label text-accent">{p.field}</p>
                  <span class="tag whitespace-nowrap">{p.status}</span>
                </div>
                <h3 class="font-serif text-2xl leading-tight group-hover:text-accent transition-colors">{p.title}</h3>
                <p class="text-inkSoft leading-relaxed mt-3 text-[15px]">{p.blurb}</p>
                <span class="mono-label mt-auto pt-5 group-hover:text-accent transition-colors">View case study →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- STATEMENT -->
    <section class="plot-grid text-center py-10 md:py-16">
      <p class="eyebrow mb-8">The bottom line</p>
      <p class="display-section max-w-[20ch] mx-auto">Your statistics should never be the reason for <em>rejection.</em></p>
    </section>

    <!-- PUBLICATIONS -->
    <section id="publications">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
        <div>
          <div class="section-head !mb-6">
            <span class="section-index">§ 04</span>
            <span class="section-kicker">Peer-reviewed</span>
          </div>
          <h2 class="display-section" data-split-reveal>Published evidence.</h2>
        </div>
        <a href={withBase('/publications')} class="link-underline font-mono text-sm">All publications →</a>
      </div>
      <div>
        {homePublications.map((pub) => (
          <a href={pub.href} target="_blank" rel="noopener noreferrer" class="edit-row group">
            <span class="font-mono text-xs text-accent uppercase tracking-widest">{pub.venue}</span>
            <span>
              <span class="font-serif text-xl md:text-2xl leading-snug group-hover:text-accent transition-colors block">{pub.title}</span>
              <span class="text-inkMuted text-sm mt-2 block">{pub.authors}</span>
            </span>
            <span class="font-mono text-[0.7rem] text-inkMuted uppercase tracking-widest whitespace-nowrap">{pub.year} →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="plot-grid">
      <div class="section-head">
        <span class="section-index">§ 05</span>
        <span class="section-kicker">Your path to publication</span>
      </div>
      <h2 class="display-section max-w-[16ch] mb-14" data-split-reveal>A transparent, structured process.</h2>
      <div class="grid gap-8 md:grid-cols-3 lg:grid-cols-5">
        {process.map((step) => (
          <div class="reveal-on-scroll border-t border-ink pt-5">
            <div class="font-serif text-5xl text-accent mb-4">{step.n}</div>
            <h3 class="font-serif text-xl mb-2 leading-snug">{step.t}</h3>
            <p class="text-inkSoft text-[15px] leading-relaxed">{step.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TOOLS -->
    <section id="tools">
      <div class="section-head">
        <span class="section-index">§ 06</span>
        <span class="section-kicker">Technical stack</span>
      </div>
      <h2 class="display-section mb-10" data-split-reveal>Tools &amp; software.</h2>
      <div class="flex flex-wrap gap-3">
        {tools.map((tool, i) => (
          <span class="tag reveal-on-scroll" style={`transition-delay:${(i % 6) * 0.04}s`}>
            <span class="dot" style={i < 3 ? 'background:var(--accent)' : ''}></span>{tool}
          </span>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <div class="section-head">
        <span class="section-index">§ 07</span>
        <span class="section-kicker">Common questions</span>
      </div>
      <h2 class="display-section mb-12" data-split-reveal>Frequently asked.</h2>
      <div class="max-w-3xl">
        {faqs.map((f) => (
          <details class="border-t border-line last:border-b">
            <summary class="cursor-pointer list-none flex items-start justify-between gap-6 py-6">
              <span class="font-serif text-xl md:text-2xl leading-snug pr-4">{f.q}</span>
              <svg class="w-5 h-5 text-inkMuted shrink-0 mt-1.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="faq-panel">
              <p class="text-inkSoft leading-relaxed pb-7 measure">{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>
</Layout>

<style>
  /* Hero entrance — pure CSS so it works without JS and preserves <em>. */
  .hero-rise { opacity: 0; transform: translateY(22px); animation: heroRise 0.95s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .hero-rise.d0 { animation-delay: 0.05s; }
  .hero-rise.d1 { animation-delay: 0.14s; }
  .hero-rise.d2 { animation-delay: 0.30s; }
  .hero-rise.d3 { animation-delay: 0.42s; }
  .hero-rise.d4 { animation-delay: 0.54s; }
  @keyframes heroRise { to { opacity: 1; transform: none; } }

  details > summary { position: relative; }
  details[open] summary svg { transform: rotate(180deg); }

  @media (prefers-reduced-motion: reduce) {
    .hero-rise { animation: none; opacity: 1; transform: none; }
  }
</style>
