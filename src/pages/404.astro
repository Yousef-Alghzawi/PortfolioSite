---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../data/site';
---
<Layout
  title="Page Not Found · Yousef Alghzawi"
  mainClass="w-full max-w-page mx-auto px-[clamp(1.25rem,4vw,3rem)] min-h-[80vh] flex items-center justify-center text-center pt-32 pb-24"
>
  <div class="max-w-xl mx-auto">
    <p class="font-serif text-accent text-8xl md:text-9xl leading-none mb-8">404</p>
    <h1 class="display-section mb-5">Data point not found.</h1>
    <p class="lead text-inkMuted mb-10">
      The page you are looking for doesn't exist or has moved. Consider it an outlier.
    </p>
    <a href={withBase('/')} class="btn-primary">Return home</a>
  </div>
</Layout>
