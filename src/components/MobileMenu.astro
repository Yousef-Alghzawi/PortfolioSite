---
import { navLinks, site, withBase } from '../data/site';
const allLinks = [{ label: 'Home', href: withBase('/') }, ...navLinks, { label: 'Apply', href: withBase('/apply') }];
---
<div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Primary navigation">
  <nav class="flex flex-col">
    {allLinks.map((link, i) => (
      <a class="mobile-nav-link" href={link.href}>
        <span class="idx">{String(i + 1).padStart(2, '0')}</span>
        {link.label}
      </a>
    ))}
  </nav>
  <div class="mt-10 font-mono text-xs text-inkMuted space-y-1">
    <a href={`mailto:${site.email}`} class="link-underline block">{site.email}</a>
    <p>{site.location}</p>
  </div>
</div>
