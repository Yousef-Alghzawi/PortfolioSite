---
import { navLinks, site, withBase } from '../data/site';
---
<header class="site-header">
  <a href={withBase('/')} class="brand" aria-label={`${site.name}, home`}>
    <span class="brand-name">{site.name}</span>
    <span class="brand-role">{site.role}</span>
  </a>

  <nav class="nav-desktop" aria-label="Primary">
    {navLinks.map((link) => (
      <a class="nav-link" href={link.href}>{link.label}</a>
    ))}
    <a class="nav-cta" href={withBase('/apply')}>Apply →</a>
  </nav>

  <button
    id="mobile-menu-button"
    class="menu-toggle"
    aria-controls="mobile-menu"
    aria-expanded="false"
  >
    <span class="sr-only">Toggle navigation</span>
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path id="menu-icon-path" stroke-linecap="round" d="M5 7h14M5 12h14M5 17h14" />
    </svg>
  </button>
</header>
