---
import Layout from './Layout.astro';
import { withBase } from '../data/site';
import '../styles/project.css';
import 'prismjs/themes/prism-tomorrow.css';

interface Props {
  title?: string;
  description?: string;
  headerImage?: string;
}
const { title, description, headerImage } = Astro.props;
const headerSrc = headerImage ? withBase(headerImage) : null;
---
<Layout title={title} description={description} mainClass="flex-1 lg:ml-[280px] px-6 md:px-10 py-10">
  <div data-case-study>
    {headerSrc && (
      <div class="fluid-header mb-12" data-fluid-header={headerSrc} aria-hidden="true">
        <img class="fluid-fallback" src={headerSrc} alt="" loading="eager" />
      </div>
    )}
    <slot />
  </div>
</Layout>

<script>
  import '../scripts/caseStudy';
</script>
