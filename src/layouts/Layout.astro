---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import { site, withBase } from '../data/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  mainClass?: string;
}

const {
  title = `${site.name} · ${site.role}`,
  description = 'Yousef Alghzawi, Clinical Biostatistician. Publication-grade statistical analysis, meta-analysis, and trial strategy for high-impact clinical research.',
  ogImage = 'assets/og-image.jpg',
  mainClass = 'w-full max-w-page mx-auto px-[clamp(1.25rem,4vw,3rem)] pt-24 md:pt-36 pb-24',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(import.meta.env.BASE_URL.replace(/\/$/, '') + '/' + ogImage, Astro.site);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="theme-color" content="#F2EEE4" />

    <script is:inline>
      (() => { try { const t = localStorage.getItem('portfolio-theme') || 'light'; document.documentElement.setAttribute('data-theme', t); } catch (e) {} })();
    </script>

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@400;500;600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>

  <body class="font-sans">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="scroll-progress" aria-hidden="true"><div class="scroll-progress-fill" id="scroll-progress-fill"></div></div>

    <Header />
    <MobileMenu />

    <main class={mainClass} id="main-content">
      <slot />
    </main>

    <footer class="border-t border-ink mt-24">
      <div class="max-w-page mx-auto px-[clamp(1.25rem,4vw,3rem)] py-20 md:py-28">
        <p class="eyebrow mb-6">Your move</p>
        <h2 class="display-section max-w-[18ch] mb-10">
          Got a paper that needs a <em>statistician?</em>
        </h2>
        <a href={withBase('/apply')} class="btn-primary">
          Apply to work with me
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>

        <div class="mt-20 pt-8 border-t border-line grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
          <div class="space-y-2">
            <a href={`mailto:${site.email}`} class="font-mono text-sm link-underline">{site.email}</a>
            <p class="font-mono text-xs text-inkMuted">{site.location}</p>
          </div>
          <div class="flex items-center gap-6 font-mono text-xs uppercase tracking-widest text-inkMuted">
            <a href={site.linkedin} target="_blank" rel="noopener" class="hover:text-ink transition-colors">LinkedIn</a>
            <a href={site.researchgate} target="_blank" rel="noopener" class="hover:text-ink transition-colors">ResearchGate</a>
          </div>
        </div>
        <p class="font-mono text-[0.7rem] text-inkMuted mt-10">© {year} {site.name}. All rights reserved.</p>
      </div>
    </footer>

    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
      <svg class="theme-icon-sun w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="4" stroke-width="2" />
        <path stroke-linecap="round" stroke-width="2" d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
      </svg>
      <svg class="theme-icon-moon w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
      </svg>
    </button>

    <button id="back-to-top" class="back-to-top" aria-label="Back to top">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      import { initMotion, destroyMotion } from '../scripts/motion';
      document.addEventListener('astro:page-load', () => initMotion());
      document.addEventListener('astro:before-swap', () => destroyMotion());
    </script>
  </body>
</html>
